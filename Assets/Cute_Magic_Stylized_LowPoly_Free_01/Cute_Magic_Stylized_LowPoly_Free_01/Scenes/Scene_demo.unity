  m_text: "\u0411\u0430\u0437\u0430\u043B\u044C\u043D\u044B\u0439 \u0441\u043B\u043E\u0439\u2014
    \u044D\u0442\u043E \u0441\u0430\u043C\u044B\u0439 \u0433\u043B\u0443\u0431\u043E\u043A\u0438\u0439
    \u0441\u043B\u043E\u0439 \u044D\u043F\u0438\u0434\u0435\u0440\u043C\u0438\u0441\u0430,
    \u0442\u043E \u0435\u0441\u0442\u044C \u043D\u0430\u0440\u0443\u0436\u043D\u043E\u0433\u043E
    \u0441\u043B\u043E\u044F \u043A\u043E\u0436\u0438. \u041E\u043D \u043B\u0435\u0436\u0438\u0442
    \u043F\u0440\u044F\u043C\u043E \u043D\u0430 \u0431\u0430\u0437\u0430\u043B\u044C\u043D\u043E\u0439
    \u043C\u0435\u043C\u0431\u0440\u0430\u043D\u0435, \u043A\u043E\u0442\u043E\u0440\u0430\u044F
    \u043E\u0442\u0434\u0435\u043B\u044F\u0435\u0442 \u044D\u043F\u0438\u0434\u0435\u0440\u043C\u0438\u0441
    \u043E\u0442 \u043F\u043E\u0434\u043B\u0435\u0436\u0430\u0449\u0435\u0439 \u0434\u0435\u0440\u043C\u044B."
