      propertyPath: m_text
      value: "\u041C\u0435\u043B\u0430\u043D\u043E\u0446\u0438\u0301\u0442\u044B 
        \u2014 \u0441\u043F\u0435\u0446\u0438\u0430\u043B\u0438\u0437\u0438\u0440\u043E\u0432\u0430\u043D\u043D\u044B\u0435
        \u043A\u043B\u0435\u0442\u043A\u0438 \u043A\u043E\u0436\u0438, \u0432\u044B\u0440\u0430\u0431\u0430\u0442\u044B\u0432\u0430\u044E\u0449\u0438\u0435
        \u043F\u0438\u0433\u043C\u0435\u043D\u0442 \u043C\u0435\u043B\u0430\u043D\u0438\u043D.
        \u0423 \u0447\u0435\u043B\u043E\u0432\u0435\u043A\u0430 \u043E\u043F\u0440\u0435\u0434\u0435\u043B\u044F\u044E\u0442
